# Copy this to .env and fill in values. Never commit .env.

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/polichan

# Auth
JWT_SECRET=generate-with-openssl-rand-hex-64
JWT_EXPIRES_IN=7d

# Admin — comma-separated wallet addresses (checksummed)
ADMIN_WALLETS=0xYourWalletAddress

# Admin fallback — ED25519 public key (PEM, single line with \n escaped)
# Generate: openssl genpkey -algorithm ED25519 -out admin-private.pem
#           openssl pkey -in admin-private.pem -pubout -out admin-public.pem
ADMIN_PUBLIC_KEY=

# Security
TRIPCODE_SECRET=generate-with-openssl-rand-hex-64
IP_HASH_SECRET=generate-with-openssl-rand-hex-64

# Uploads
UPLOAD_DIR=./public/uploads
MAX_IMAGE_MB=8
MAX_VIDEO_MB=32
